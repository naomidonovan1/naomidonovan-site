AUTH_SECRET=           # `openssl rand -base64 32`
AUTH_GOOGLE_ID=        # Google Cloud OAuth client ID
AUTH_GOOGLE_SECRET=    # Google Cloud OAuth client secret
ALLOWED_EMAILS=        # comma-separated, lowercase, e.g. "you@gmail.com,friend@example.com"
NEXTAUTH_URL=http://localhost:3000  # only needed if Auth.js v5 can't infer it
